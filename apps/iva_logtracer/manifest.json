{
    "name": "iva-logtracer",
    "displayName": "Log Tracer",
    "version": "1.0.0",
    "description": "IVA Log Tracer - correlate and analyze logs across services",
    "tags": ["internal", "devops"],
    "components": {
        "frontend": {
            "enabled": true,
            "port": 5192,
            "remoteName": "iva_logtracer",
            "exposedModule": "./App",
            "runner": {
                "script": "pnpm",
                "args": "run dev",
                "cwd": "frontend"
            }
        },
        "backend": {
            "enabled": true,
            "port": 8190,
            "language": "python",
            "healthCheck": "/health",
            "apiPrefix": "/api/logtracer",
            "runner": {
                "script": "uv",
                "args": "run -m src.main",
                "cwd": "backend"
            }
        }
    },
    "integration": {
        "admin": {
            "sidebar": {
                "enabled": true,
                "section": "Management",
                "icon": "Terminal",
                "label": "Log Tracer",
                "path": "/iva-logtracer"
            },
            "routes": [
                { "path": "/iva-logtracer/*", "component": "./App" }
            ]
        }
    }
}
