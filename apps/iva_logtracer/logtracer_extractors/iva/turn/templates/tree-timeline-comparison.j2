<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    
    <link rel="stylesheet" href="../static/tree-timeline-renderer.css">
    
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #f8f9fa;
            padding: 2rem;
            margin: 0;
        }
        .container {
            max-width: 1600px;
            margin: 0 auto;
        }
        .comparison-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(700px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }
        .turn-card {
            background: white;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 1.5rem;
        }
        .turn-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #dee2e6;
        }
        .turn-card-title {
            font-size: 1.25rem;
            font-weight: 600;
        }
        .turn-card-stats {
            display: flex;
            gap: 1rem;
            font-size: 0.875rem;
        }
        .stat-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 4px;
            background: #e9ecef;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>{{ title }}</h1>
        <p>{{ description }}</p>
        
        <div class="comparison-grid">
            {% for item in comparison_data %}
            <div class="turn-card">
                <div class="turn-card-header">
                    <div class="turn-card-title">Turn {{ item.turn_number }}</div>
                    <div class="turn-card-stats">
                        <span class="stat-badge">{{ "%.2f"|format(item.duration_ms) }}ms</span>
                        {% if item.ttft_ms %}
                        <span class="stat-badge">TTFT: {{ "%.2f"|format(item.ttft_ms) }}ms</span>
                        {% endif %}
                    </div>
                </div>
                <div id="timeline-{{ loop.index }}"></div>
            </div>
            {% endfor %}
        </div>
    </div>

    <script src="../static/tree-timeline-renderer.js"></script>
    <script>
        const comparisonData = {{ comparison_data | tojson }};
        
        comparisonData.forEach((item, index) => {
            const renderer = new TreeTimelineRenderer({
                container: `#timeline-${index + 1}`
            });
            renderer.render(item.tree_data);
        });
    </script>
</body>
</html>
