# Kibana 连接配置
# 复制此文件为 .env 并填入实际值

# Kibana URL (支持通过 Kibana 代理访问 ES)
KIBANA_URL=https://kibana.your-company.com

# 或者直连 Elasticsearch URL (需设置 KIBANA_USE_PROXY=false)
# KIBANA_ES_URL=https://elasticsearch.your-company.com:9200

# 认证信息（用户名 + 密码）
KIBANA_USERNAME=your-username
KIBANA_PASSWORD=your-password

# API Key 认证（可选，优先于用户名密码）
# KIBANA_API_KEY=your-api-key

# 默认索引模式
KIBANA_INDEX=*:*-logs-air_assistant_runtime-*

# 是否通过 Kibana 代理访问 ES (默认 true)
# 如果你只有 Kibana 地址，保持 true
# 如果你有直接的 ES 地址，设置为 false
KIBANA_USE_PROXY=true

# SSL 证书验证（生产环境建议 true）
KIBANA_VERIFY_CERTS=false

# 连接超时（秒）
KIBANA_TIMEOUT=30

# 输出目录（可选）
KIBANA_OUTPUT_DIR=./output

