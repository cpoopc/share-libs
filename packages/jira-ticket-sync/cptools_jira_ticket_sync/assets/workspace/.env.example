# Required for real Jira operations
JIRA_URL=https://jira.ringcentral.com
JIRA_TOKEN=replace-with-api-token
JIRA_USE_BEARER=true

# Only required when the Jira instance still allows basic auth
# JIRA_USERNAME=your.name@example.com

# Optional
# JIRA_STORY_POINTS_FIELD=customfield_10016
# JIRA_TICKET_SYNC_WORKSPACE_ROOT=/path/to/jira-ticket-sync-workspace
# JIRA_TICKET_SYNC_MANIFEST_ROOT=/path/to/jira-ticket-sync-workspace/manifests
# JIRA_TICKET_SYNC_PROFILE_ROOT=/path/to/jira-ticket-sync-workspace/profiles
# JIRA_TICKET_SYNC_TEMPLATE_ROOT=/path/to/jira-ticket-sync-workspace/templates/imported
# JIRA_TICKET_SYNC_PROJECT_CONFIG_PATH=/path/to/jira-ticket-sync-workspace/project-config.yaml
# JIRA_TICKET_SYNC_STATE_FILE=/path/to/jira-ticket-sync-workspace/state/sync-state.json
# JIRA_TICKET_SYNC_FIELD_CLASSIFICATION_ROOT=/path/to/jira-ticket-sync-workspace/state/field-classification
